---
// Composant Hero — fond bleu nuit, texte blanc, CTA cuivre
export interface Props {
  titre: string;
  sousTitre: string;
  badges?: string[];
  ctaPrimary?: { text: string; href: string };
  ctaSecondary?: { text: string; href: string };
}

const {
  titre,
  sousTitre,
  badges = [],
  ctaPrimary = { text: 'Devis gratuit 24h', href: '/contact' },
  ctaSecondary = { text: '06 50 50 50 50', href: 'tel:0650505050' },
} = Astro.props;
---

<section class="relative bg-elekio-navy overflow-hidden">
  <!-- Fond décoratif -->
  <div class="absolute inset-0" aria-hidden="true">
    <div class="absolute top-0 right-0 w-96 h-96 bg-elekio-copper/10 rounded-full blur-3xl -translate-y-1/2 translate-x-1/4"></div>
    <div class="absolute bottom-0 left-0 w-64 h-64 bg-elekio-copper/5 rounded-full blur-3xl translate-y-1/3 -translate-x-1/4"></div>
    <div class="absolute inset-0 bg-[radial-gradient(ellipse_at_center,rgba(196,121,91,0.08)_0%,transparent_70%)]"></div>
  </div>

  <div class="relative max-w-7xl mx-auto px-4 sm:px-6 py-16 md:py-24 lg:py-32">
    <div class="max-w-3xl">

      <!-- Badges -->
      {badges.length > 0 && (
        <div class="flex flex-wrap gap-2 mb-6 animate-fade-in">
          {badges.map(badge => (
            <span class="badge">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg>
              {badge}
            </span>
          ))}
        </div>
      )}

      <!-- Titre -->
      <h1 class="text-3xl sm:text-4xl md:text-5xl lg:text-6xl font-black text-white leading-[1.08] mb-5 animate-slide-up">
        {titre.split('Tarn').length > 1 ? (
          <>
            {titre.split('Tarn')[0]}<span class="text-elekio-copper">Tarn</span>{titre.split('Tarn')[1] || ''}
          </>
        ) : (
          titre
        )}
      </h1>

      <!-- Sous-titre -->
      <p class="text-base sm:text-lg md:text-xl text-white/70 leading-relaxed mb-8 max-w-2xl animate-slide-up" style="animation-delay: 0.15s">
        {sousTitre}
      </p>

      <!-- CTAs -->
      <div class="flex flex-col sm:flex-row gap-3.5 animate-slide-up" style="animation-delay: 0.3s">
        <a href={ctaPrimary.href} class="btn-primary text-center !text-lg !px-8 !py-4">
          {ctaPrimary.text}
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="ml-2" aria-hidden="true"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
        </a>
        <a href={ctaSecondary.href} class="btn-secondary text-center !text-lg !px-8 !py-4">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="mr-2" aria-hidden="true"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
          {ctaSecondary.text}
        </a>
      </div>
    </div>
  </div>
</section>
