---
// Header component
const navItems = [
  { label: 'Accueil', href: '/' },
  { label: 'Services', href: '/services' },
  { label: 'Réalisations', href: '/realisations' },
  { label: 'À propos', href: '/about' },
  { label: 'Contact', href: '/contact' },
];
const currentPath = Astro.url.pathname;
---

<header class="sticky top-0 z-50 bg-elekio-navy/95 backdrop-blur-md border-b border-white/10 shadow-lg">
  <div class="max-w-7xl mx-auto px-4 sm:px-6">
    <div class="flex items-center justify-between h-16 md:h-20">

      <!-- Logo -->
      <a href="/" class="flex items-center gap-2.5 shrink-0 group" aria-label="Elekio - Accueil">
        <svg width="40" height="40" viewBox="0 0 100 100" fill="none" xmlns="http://www.w3.org/2000/svg" class="w-9 h-9 md:w-10 md:h-10 transition-transform group-hover:scale-105" aria-hidden="true">
          <circle cx="50" cy="50" r="48" fill="#000c42" stroke="#c4795b" stroke-width="4"/>
          <text x="50" y="68" text-anchor="middle" font-family="Inter, sans-serif" font-weight="900" font-size="52" fill="#c4795b">E</text>
          <path d="M30 38 L70 38" stroke="#c4795b" stroke-width="2.5" stroke-linecap="round"/>
          <path d="M30 46 L70 46" stroke="#c4795b" stroke-width="2.5" stroke-linecap="round"/>
          <path d="M35 54 L65 54" stroke="#c4795b" stroke-width="2.5" stroke-linecap="round"/>
        </svg>
        <span class="text-white font-black text-xl md:text-2xl tracking-tight">
          <span class="text-elekio-copper">E</span>lekio
        </span>
      </a>

      <!-- Desktop nav -->
      <nav class="hidden lg:flex items-center gap-1" aria-label="Navigation principale">
        {navItems.map(item => (
          <a
            href={item.href}
            class={`px-4 py-2 rounded-lg text-sm font-medium transition-all duration-200 ${
              currentPath === item.href
                ? 'bg-white/10 text-elekio-copper'
                : 'text-white/80 hover:text-white hover:bg-white/5'
            }`}
          >
            {item.label}
          </a>
        ))}
      </nav>

      <!-- Desktop CTA -->
      <div class="hidden lg:flex items-center gap-3">
        <a href="tel:0650505050" class="flex items-center gap-2 text-white/90 hover:text-white transition-colors text-sm font-medium">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
          06 50 50 50 50
        </a>
        <a href="/contact" class="btn-primary text-sm !px-4 !py-2.5">
          Devis gratuit
        </a>
      </div>

      <!-- Mobile hamburger -->
      <button
        id="menu-toggle"
        class="lg:hidden flex items-center justify-center w-10 h-10 rounded-lg text-white hover:bg-white/10 transition-colors"
        aria-label="Menu"
        aria-expanded="false"
        type="button"
      >
        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" aria-hidden="true">
          <line x1="3" y1="6" x2="21" y2="6" id="line1" />
          <line x1="3" y1="12" x2="21" y2="12" id="line2" />
          <line x1="3" y1="18" x2="21" y2="18" id="line3" />
        </svg>
      </button>
    </div>

    <!-- Mobile menu -->
    <div id="mobile-menu" class="hidden lg:hidden border-t border-white/10 pb-4 animate-fade-in">
      <nav class="flex flex-col gap-1 pt-3" aria-label="Navigation mobile">
        {navItems.map(item => (
          <a
            href={item.href}
            class={`px-4 py-3 rounded-lg text-base font-medium transition-all ${
              currentPath === item.href
                ? 'bg-white/10 text-elekio-copper'
                : 'text-white/80 hover:text-white hover:bg-white/5'
            }`}
          >
            {item.label}
          </a>
        ))}
        <a href="tel:0650505050" class="mt-2 flex items-center justify-center gap-2 px-4 py-3 bg-elekio-copper text-white font-bold rounded-lg text-base">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
          Appeler maintenant
        </a>
      </nav>
    </div>
  </div>
</header>
