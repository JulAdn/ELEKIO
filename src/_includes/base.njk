<!DOCTYPE html>
<html lang="fr">
<head>
<meta charset="UTF-8">
<meta name="google-site-verification" content="g8RZxrg2JnI3FMPADEeKH-jYWPKXyNIrwyvGQQ_jAz8" />
<!-- Google Tag Manager -->
<script>(function(w,d,s,l,i){w[l]=w[l]||[];w[l].push({'gtm.start':
new Date().getTime(),event:'gtm.js'});var f=d.getElementsByTagName(s)[0],
j=d.createElement(s),dl=l!='dataLayer'?'&l='+l:'';j.async=true;j.src=
'https://www.googletagmanager.com/gtm.js?id='+i+dl;f.parentNode.insertBefore(j,f);
})(window,document,'script','dataLayer','GTM-MC2MQQ23');</script>
<!-- End Google Tag Manager -->
<meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover">
<meta http-equiv="X-UA-Compatible" content="IE=edge">
<title>{{ title or "Elekio — Électricien Tarn 81" }}</title>
<meta name="description" content="{{ description or "Électricien Tarn 81 — Saint-Sulpice-la-Pointe. Dépannage urgence 4h, installation neuve, rénovation normes. Devis gratuit 24h." }}">
<meta name="theme-color" content="#000c42" media="(prefers-color-scheme:light)">
<meta name="theme-color" content="#0f172a" media="(prefers-color-scheme:dark)">
<meta name="format-detection" content="telephone=yes">
{% set path_parts = page.url.split('/') %}
{% set prefix = '../' if path_parts | length > 2 else '' %}
<link rel="icon" type="image/png" href="{{ prefix }}favicon.png">
<link rel="apple-touch-icon" href="{{ prefix }}apple-touch-icon.png">
<link rel="canonical" href="{{ canonical or "https://www.elekio.fr/?" + page.url }}">
{% if og_title %}<meta property="og:title" content="{{ og_title }}">
{% else %}<meta property="og:title" content="{{ title or "Électricien Tarn (81) — Elekio" }}">{% endif %}
{% if og_description %}<meta property="og:description" content="{{ og_description }}">
{% else %}<meta property="og:description" content="{{ description or "Électricien Tarn 81" }}">{% endif %}
<meta property="og:url" content="{{ canonical or "https://www.elekio.fr" + page.url }}">
<meta property="og:type" content="website">
<meta property="og:locale" content="fr_FR">
{% if og_image %}<meta property="og:image" content="{{ og_image }}">
{% else %}<meta property="og:image" content="https://www.elekio.fr/logo-elekio.png">{% endif %}
<meta name="twitter:card" content="summary">

{% block schema %}{% endblock %}

<style>
{% include "shared.css" %}
{% block pageCss %}{% endblock %}
</style>
<link rel="stylesheet" href="{{ prefix }}style.css">
</head>
<body>
<!-- Google Tag Manager (noscript) -->
<noscript><iframe src="https://www.googletagmanager.com/ns.html?id=GTM-MC2MQQ23"
height="0" width="0" style="display:none;visibility:hidden"></iframe></noscript>
<!-- End Google Tag Manager (noscript) -->

{% include "header.njk" %}

{{ content | safe }}

<div class="mobile-sticky">
  <a href="tel:0680506709" class="ms-call">📞 Appeler</a>
  <a href="{{ prefix }}contact.html" class="ms-devis">📄 Devis gratuit</a>
</div>

{% include "footer.njk" %}

<script>
document.getElementById('menuToggle').addEventListener('click',function(){this.classList.toggle('active');document.getElementById('mainNav').classList.toggle('open');});
document.querySelectorAll('.nav a').forEach(function(a){a.addEventListener('click',function(){document.getElementById('menuToggle').classList.remove('active');document.getElementById('mainNav').classList.remove('open');});});
(function(){var o=new IntersectionObserver(function(e){e.forEach(function(e){if(e.isIntersecting){e.style.animationPlayState='running';o.unobserve(e.target);}});},{threshold:0.1});document.querySelectorAll('.animate-fade-up').forEach(function(e){e.style.animationPlayState='paused';o.observe(e);});})();
</script>

{% block bodyEnd %}{% endblock %}
</body>
</html>
